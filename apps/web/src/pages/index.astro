---
import { readFileSync, readdirSync } from 'node:fs'
import { join } from 'node:path'
import Layout from '../layouts/Layout.astro'

interface LeyCard {
  titulo: string
  identificador: string
  rango: string
  estado: string
}

function parseLeyCard(content: string): LeyCard {
  const parts = content.split(/^---\s*$/m)
  const yamlBlock = parts[1] ?? ''
  const result: Record<string, string> = {}
  for (const line of yamlBlock.split('\n')) {
    const match = line.match(/^(\w+):\s*"?([^"]*?)"?\s*$/)
    if (match) result[match[1]] = match[2].trim()
  }
  return result as unknown as LeyCard
}

const leyesDir = join(process.cwd(), '../../leyes/pe')
const leyFiles = readdirSync(leyesDir).filter((f) => f.endsWith('.md') && !f.startsWith('HISTORIAL'))
const leyes = leyFiles
  .map((f) => parseLeyCard(readFileSync(join(leyesDir, f), 'utf-8')))
  .sort((a, b) => a.titulo.localeCompare(b.titulo, 'es'))

const rangoLabels: Record<string, string> = {
  constitucion: 'Constitución',
  ley: 'Ley',
  'ley-organica': 'Ley Orgánica',
  'decreto-legislativo': 'D. Legislativo',
  'decreto-urgencia': 'D. Urgencia',
  'decreto-supremo': 'D. Supremo',
  reglamento: 'Reglamento',
}

const endpoints = [
  { path: '/api/normas', desc: 'Listar y buscar normas' },
  { path: '/api/normas/:id', desc: 'Obtener norma por identificador' },
  { path: '/api/normas/por-fecha/:fecha', desc: 'Normas publicadas en una fecha' },
  { path: '/api/normas/actualizadas', desc: 'Normas modificadas recientemente' },
  { path: '/api/calendario/:year/:month', desc: 'Calendario de publicaciones' },
  { path: '/api/stats', desc: 'Estadísticas generales' },
]
---

<Layout title="Legalize PE — Legislación Peruana">
  <main id="main-content">

    <!-- ══ USUARIO ══════════════════════════════════════════════════ -->

    <section class="hero">
      <div class="container">
        <h1>Legalize — Perú</h1>
        <p class="tagline">
          Legislación peruana en texto plano.<br />
          Cada ley es un fichero Markdown, cada reforma un commit.
        </p>

        <form class="search-form" action="/leyes" method="get">
          <div class="search-wrap">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
            <input
              type="text"
              name="q"
              placeholder="Código Civil, Ley 26702, DLeg 1310…"
              class="search-input"
              autocomplete="off"
              aria-label="Buscar normas"
            />
            <button type="submit" class="search-btn">Buscar</button>
          </div>
        </form>

        <div class="hero-links">
          <a href="/leyes">Ver normas ({leyes.length})</a>
          <a href="https://github.com/crafter-research/legalize-pe" target="_blank" rel="noopener">GitHub</a>
          <a href="#dev">Para desarrolladores</a>
          <a href="https://ko-fi.com/shiaradesign" target="_blank" rel="noopener" class="bmc-link">☕ Invítame un café</a>
        </div>
      </div>
    </section>

    <!-- Normas grid -->
    <section class="section" id="normas">
      <div class="container">
        <div class="leyes-grid">
          {leyes.slice(0, 24).map((ley) => (
            <a href={`/leyes/${ley.identificador}`} class="ley-card">
              <div class="ley-top">
                <span class="badge">{rangoLabels[ley.rango] ?? ley.rango}</span>
                {ley.estado !== 'vigente' && (
                  <span class="badge badge-outdated">{ley.estado}</span>
                )}
              </div>
              <span class="ley-titulo">{ley.titulo}</span>
            </a>
          ))}
        </div>
        <div class="grid-footer">
          <a href="/leyes" class="link-more">Ver todas las normas →</a>
        </div>
      </div>
    </section>

    <!-- ══ DESARROLLADOR ════════════════════════════════════════════ -->

    <section class="section section-dev" id="dev">
      <div class="container">
        <p class="dev-label">Para desarrolladores</p>

        <div class="dev-grid">
          <!-- Git -->
          <div class="dev-block">
            <h2>Repositorio Git</h2>
            <pre><code>git clone https://github.com/crafter-research/legalize-pe.git

# ¿Qué dice el Artículo 2 de la Constitución?
grep -A 20 "Artículo 2" leyes/pe/constitucion-1993.md

# ¿Cuándo cambió?
git log --oneline -- leyes/pe/constitucion-1993.md</code></pre>
            <p class="dev-note">
              Estructura: <code>leyes/pe/</code> legislación nacional ·
              <code>leyes/pe-lima/</code> región Lima · etc.
            </p>
          </div>

          <!-- API -->
          <div class="dev-block">
            <h2>API REST</h2>
            <pre><code>curl "https://legalize.crafter.ing/api/normas?q=bancos"
curl "https://legalize.crafter.ing/api/normas/dleg-295"</code></pre>
            <table class="api-table">
              <tbody>
                {endpoints.map((e) => (
                  <tr>
                    <td><code>{e.path}</code></td>
                    <td class="api-desc">{e.desc}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <p class="dev-source">
          Contenido del <a href="https://spij.minjus.gob.pe" target="_blank" rel="noopener">SPIJ</a>
          (Ministerio de Justicia). Dominio público según DLeg 822 Art. 9.
          Código MIT.
        </p>
      </div>
    </section>

    <footer>
      <div class="container footer-content">
        <span>Un proyecto de <a href="https://www.crafterstation.com" target="_blank" rel="noopener">Crafter Station</a></span>
        <span>
          <a href="https://github.com/crafter-research/legalize-pe" target="_blank" rel="noopener">GitHub</a>
          ·
          <a href="https://github.com/legalize-dev/legalize-es" target="_blank" rel="noopener">legalize-es</a>
        </span>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .hero {
    padding: 5rem 0 3rem;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .tagline {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  /* Search */
  .search-form {
    max-width: 520px;
    margin: 0 auto 1.5rem;
  }

  .search-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.5rem 0.5rem 0.5rem 1rem;
    transition: border-color 0.15s;
  }

  .search-wrap:focus-within {
    border-color: var(--color-accent);
  }

  .search-icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-text);
    font-size: 0.95rem;
    padding: 0.4rem;
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-btn {
    background: #fff;
    color: #000;
    border: none;
    padding: 0.5rem 1.1rem;
    border-radius: 7px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s;
  }

  .search-btn:hover {
    background: #ddd;
  }

  .hero-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    font-size: 0.9rem;
  }

  .hero-links a {
    color: var(--color-text-muted);
    transition: color 0.15s;
  }

  .hero-links a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .bmc-link {
    color: #FF5E5B !important;
  }

  .bmc-link:hover {
    color: #ff7c7a !important;
  }

  /* Sections */
  .section {
    padding: 3rem 0;
  }

  /* Laws grid */
  .leyes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.75rem;
  }

  .ley-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem 1.125rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .ley-card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .ley-top {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .ley-titulo {
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .badge {
    display: inline-block;
    padding: 0.15em 0.55em;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    background: #27272a;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .badge-outdated {
    background: transparent;
    color: #888;
    border-color: #444;
  }

  .grid-footer {
    margin-top: 1.5rem;
    text-align: center;
  }

  .link-more {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .link-more:hover {
    color: var(--color-text);
  }

  /* Developer section */
  .section-dev {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
  }

  .dev-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .dev-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .dev-block h2 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .dev-note {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* API table */
  .api-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
    margin-top: 1rem;
  }

  .api-table td {
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .api-table tr:last-child td {
    border-bottom: none;
  }

  .api-desc {
    color: var(--color-text-muted);
    padding-left: 1rem;
  }

  .dev-source {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }

  /* Footer */
  footer {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer-content a {
    color: var(--color-text-muted);
  }

  .footer-content a:hover {
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 1.75rem;
    }

    .dev-grid {
      grid-template-columns: 1fr;
    }

    .footer-content {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>

<script>
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault()
      const input = document.querySelector('.search-input') as HTMLInputElement
      input?.focus()
      input?.select()
    }
  })
</script>
