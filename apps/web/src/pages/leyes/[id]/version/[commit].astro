---
import { marked } from 'marked'
import Layout from '../../../../layouts/Layout.astro'

export const prerender = false

const { id, commit } = Astro.params

if (!id || !commit) {
  return Astro.redirect('/leyes')
}

let content = ''
let authorDate = ''
let message = ''
let error = ''

try {
  const res = await fetch(`${Astro.url.origin}/api/normas/${id}/at/${commit}`)
  if (!res.ok) {
    throw new Error('Failed to fetch version')
  }
  const { data } = await res.json()
  content = data.content
  authorDate = data.authorDate
  message = data.message
} catch (e) {
  error = 'No se pudo cargar esta versión'
}

function parseFrontmatter(rawContent: string): { meta: Record<string, string>; body: string } {
  const parts = rawContent.split(/^---\s*$/m)
  const yamlBlock = parts[1] ?? ''
  const body = parts.slice(2).join('---').trim()
  const result: Record<string, string> = {}
  for (const line of yamlBlock.split('\n')) {
    const match = line.match(/^(\w+):\s*"?([^"]*?)"?\s*$/)
    if (match) {
      result[match[1]] = match[2].trim()
    }
  }
  return { meta: result, body }
}

const { meta, body } = content ? parseFrontmatter(content) : { meta: {}, body: '' }
const htmlContent = body ? await marked(body) : ''
const formattedDate = authorDate ? new Date(authorDate).toLocaleDateString('es-PE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}) : ''
---

<Layout title={`${meta.titulo ?? id} — Versión ${commit.slice(0, 7)}`}>
  <main>
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span>/</span>
        <a href="/leyes">Normas</a>
        <span>/</span>
        <a href={`/leyes/${id}`}>{id}</a>
        <span>/</span>
        <span>Versión {commit.slice(0, 7)}</span>
      </nav>

      {error ? (
        <div class="error-box">
          <p>{error}</p>
          <a href={`/leyes/${id}`} class="btn btn-primary">Volver a la norma actual</a>
        </div>
      ) : (
        <>
          <div class="version-banner">
            <div class="version-info">
              <span class="version-label">Versión histórica</span>
              <span class="version-date">{formattedDate}</span>
            </div>
            <p class="version-message">{message.split('\n')[0]}</p>
            <a href={`/leyes/${id}`} class="btn btn-secondary">Ver versión actual</a>
          </div>

          <div class="page-header">
            <h1>{meta.titulo ?? id}</h1>
          </div>

          <article class="content-box prose" set:html={htmlContent} />
        </>
      )}
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .breadcrumb span:not(:last-child) {
    color: var(--color-border);
  }

  .version-banner {
    background: #1a1a2e;
    border: 1px solid #3b3b5c;
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .version-info {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .version-label {
    background: #3b3b5c;
    color: #a5a5c0;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .version-date {
    color: var(--color-text);
    font-weight: 500;
  }

  .version-message {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.875rem;
    transition: all 0.2s;
    border: none;
    cursor: pointer;
    text-decoration: none;
    width: fit-content;
  }

  .btn-primary {
    background: #ffffff;
    color: #000000;
  }

  .btn-primary:hover {
    background: #cccccc;
  }

  .btn-secondary {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-secondary:hover {
    background: var(--color-border);
  }

  .error-box {
    text-align: center;
    padding: 4rem 2rem;
  }

  .error-box p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .content-box {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
  }

  .prose {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .prose :global(h1) { font-size: 1.5rem; font-weight: 700; margin: 2.5rem 0 1rem; }
  .prose :global(h2) { font-size: 1.25rem; font-weight: 600; margin: 2rem 0 0.75rem; }
  .prose :global(h3) { font-size: 1.1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .prose :global(p) { margin: 0.75rem 0; }
  .prose :global(ul), .prose :global(ol) { margin: 0.75rem 0; padding-left: 1.5rem; }
  .prose :global(li) { margin: 0.25rem 0; }
</style>
