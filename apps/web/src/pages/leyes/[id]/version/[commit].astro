---
export const prerender = false

import { marked } from 'marked'
import Layout from '../../../../layouts/Layout.astro'

const { id, commit } = Astro.params

if (!id || !commit) {
  return Astro.redirect('/404')
}

const API_BASE = 'http://localhost:3001'
let data: {
  content: string
  commit: {
    sha: string
    message: string
    authorDate: string
  }
} | null = null

try {
  const res = await fetch(`${API_BASE}/api/normas/${id}/at/${commit}`)
  if (!res.ok) {
    return Astro.redirect('/404')
  }
  const json = await res.json()
  data = json.data
} catch (err) {
  return Astro.redirect('/404')
}

if (!data) {
  return Astro.redirect('/404')
}

function parseFrontmatter(content: string): { titulo: string; rango: string } {
  const parts = content.split(/^---\s*$/m)
  const yamlBlock = parts[1] ?? ''
  const result: Record<string, string> = {}
  for (const line of yamlBlock.split('\n')) {
    const match = line.match(/^(\w+):\s*"?([^"]*?)"?\s*$/)
    if (match) {
      result[match[1]] = match[2].trim()
    }
  }
  return {
    titulo: result['titulo'] ?? id ?? 'Sin título',
    rango: result['rango'] ?? 'ley'
  }
}

const metadata = parseFrontmatter(data.content)
const bodyContent = data.content.split(/^---\s*$/m).slice(2).join('---').trim()
const htmlContent = await marked(bodyContent)

const rangoLabels: Record<string, string> = {
  constitucion: 'Constitución',
  ley: 'Ley',
  'decreto-legislativo': 'Decreto Legislativo',
  'decreto-urgencia': 'Decreto de Urgencia',
  'decreto-supremo': 'Decreto Supremo',
}
---

<Layout title={`Versión histórica - ${metadata.titulo} — Legalize PE`} description={`Versión histórica de ${metadata.titulo} del ${new Date(data.commit.authorDate).toLocaleDateString('es-PE')}`}>
  <main>
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span>/</span>
        <a href="/leyes">Normas</a>
        <span>/</span>
        <a href={`/leyes/${id}`}>{id}</a>
        <span>/</span>
        <span>Versión histórica</span>
      </nav>

      <div class="version-banner">
        <div class="banner-content">
          <svg class="banner-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
          </svg>
          <div class="banner-text">
            <strong>Versión histórica</strong>
            <span>{new Date(data.commit.authorDate).toLocaleDateString('es-PE', { dateStyle: 'long' })}</span>
            <span class="commit-message">{data.commit.message}</span>
          </div>
        </div>
        <a href={`/leyes/${id}`} class="btn-current">Ver versión actual</a>
      </div>

      <div class="page-header">
        <h1>{metadata.titulo}</h1>
        <div class="meta-badges">
          <span class="badge badge-rango">
            {rangoLabels[metadata.rango] ?? metadata.rango}
          </span>
          <span class="badge badge-historical">Histórica</span>
        </div>
      </div>

      <article class="content-box prose" set:html={htmlContent} />
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .breadcrumb span:not(:last-child) {
    color: var(--color-border);
  }

  .version-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1rem 1.25rem;
    background: #422006;
    border: 1px solid #78350f;
    border-radius: 8px;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .banner-content {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    flex: 1;
    min-width: 0;
  }

  .banner-icon {
    flex-shrink: 0;
    color: #fbbf24;
    margin-top: 0.125rem;
  }

  .banner-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .banner-text strong {
    color: #fbbf24;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .banner-text span {
    font-size: 0.85rem;
    color: #d97706;
  }

  .commit-message {
    font-size: 0.8rem;
    color: #92400e;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .btn-current {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    background: #fbbf24;
    color: #000000;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .btn-current:hover {
    background: #f59e0b;
    text-decoration: none;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .meta-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .badge {
    display: inline-block;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .badge-rango {
    background: #27272a;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .badge-historical {
    background: #422006;
    color: #fbbf24;
    border: 1px solid #78350f;
  }

  .content-box {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
  }

  .prose {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .prose :global(h1) {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.01em;
  }

  .prose :global(h2) {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }

  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    font-size: 1rem;
    font-weight: 600;
    margin: 1.25rem 0 0.5rem;
  }

  .prose :global(p) {
    margin: 0.75rem 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0.75rem 0;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin: 0.25rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.875rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .prose :global(th) {
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text-muted);
  }

  .prose :global(strong) {
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  @media (max-width: 640px) {
    .version-banner {
      flex-direction: column;
      align-items: stretch;
    }

    .btn-current {
      width: 100%;
    }
  }
</style>
