---
export const prerender = false

import Layout from '../../../layouts/Layout.astro'

const { id } = Astro.params

if (!id) {
  return Astro.redirect('/404')
}

const from = Astro.url.searchParams.get('from')
const to = Astro.url.searchParams.get('to')

if (!from || !to) {
  return Astro.redirect(`/leyes/${id}`)
}

const API_BASE = 'http://localhost:3001'
let data: {
  from: {
    sha: string
    message: string
    authorDate: string
  }
  to: {
    sha: string
    message: string
    authorDate: string
  }
  stats: {
    insertions: number
    deletions: number
  }
  hunks: Array<{
    oldStart: number
    oldLines: number
    newStart: number
    newLines: number
    lines: string[]
  }>
} | null = null

let metadata: { titulo: string } = { titulo: id ?? 'Sin título' }

try {
  const res = await fetch(`${API_BASE}/api/normas/${id}/diff?from=${from}&to=${to}`)
  if (!res.ok) {
    return Astro.redirect('/404')
  }
  const json = await res.json()
  data = json.data

  // Fetch current version to get metadata
  const metaRes = await fetch(`${API_BASE}/api/normas/${id}`)
  if (metaRes.ok) {
    const metaJson = await metaRes.json()
    if (metaJson.data?.titulo) {
      metadata = { titulo: metaJson.data.titulo }
    }
  }
} catch (err) {
  return Astro.redirect('/404')
}

if (!data) {
  return Astro.redirect('/404')
}
---

<Layout title={`Comparar versiones - ${metadata.titulo} — Legalize PE`} description={`Comparación de versiones de ${metadata.titulo}`}>
  <main>
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span>/</span>
        <a href="/leyes">Normas</a>
        <span>/</span>
        <a href={`/leyes/${id}`}>{id}</a>
        <span>/</span>
        <span>Comparar versiones</span>
      </nav>

      <header class="diff-header">
        <h1>Comparar versiones</h1>
        <p class="diff-title">{metadata.titulo}</p>
        <a href={`/leyes/${id}`} class="btn-back">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
          </svg>
          Volver a {id}
        </a>
      </header>

      <div class="diff-stats">
        <div class="stats-row">
          <span class="stat-label">Cambios:</span>
          <div class="stat-values">
            <span class="additions">+{data.stats.insertions}</span>
            <span class="deletions">-{data.stats.deletions}</span>
          </div>
        </div>
      </div>

      <div class="diff-dates">
        <div class="date-box date-from">
          <div class="date-label">Desde</div>
          <div class="date-value">{new Date(data.from.authorDate).toLocaleDateString('es-PE', { dateStyle: 'long' })}</div>
          <div class="commit-msg">{data.from.message}</div>
        </div>
        <svg class="arrow-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
        <div class="date-box date-to">
          <div class="date-label">Hasta</div>
          <div class="date-value">{new Date(data.to.authorDate).toLocaleDateString('es-PE', { dateStyle: 'long' })}</div>
          <div class="commit-msg">{data.to.message}</div>
        </div>
      </div>

      <div class="diff-content">
        {data.hunks.length === 0 ? (
          <div class="no-changes">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p>No hay diferencias entre estas versiones</p>
          </div>
        ) : (
          data.hunks.map(hunk => (
            <div class="hunk">
              <div class="hunk-header">
                @@ -{hunk.oldStart},{hunk.oldLines} +{hunk.newStart},{hunk.newLines} @@
              </div>
              <div class="hunk-lines">
                {hunk.lines.map(line => {
                  const type = line.startsWith('+') ? 'addition' : line.startsWith('-') ? 'deletion' : 'context'
                  return (
                    <div class={`line line-${type}`}>
                      <span class="line-marker">{line[0] || ' '}</span>
                      <span class="line-content">{line.slice(1)}</span>
                    </div>
                  )
                })}
              </div>
            </div>
          ))
        )}
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .breadcrumb span:not(:last-child) {
    color: var(--color-border);
  }

  .diff-header {
    margin-bottom: 2rem;
  }

  .diff-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .diff-title {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-back:hover {
    background: var(--color-border);
    text-decoration: none;
  }

  .diff-stats {
    padding: 1rem 1.25rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .stat-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-values {
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .additions {
    color: #22c55e;
  }

  .deletions {
    color: #ef4444;
  }

  .diff-dates {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .date-box {
    flex: 1;
    min-width: 250px;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
  }

  .date-from {
    border-left: 3px solid #ef4444;
  }

  .date-to {
    border-left: 3px solid #22c55e;
  }

  .date-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .date-value {
    font-size: 0.95rem;
    color: var(--color-text);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .commit-msg {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .arrow-icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .diff-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .no-changes {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
    color: var(--color-text-muted);
  }

  .no-changes svg {
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .no-changes p {
    font-size: 1rem;
  }

  .hunk {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .hunk-header {
    padding: 0.5rem 1rem;
    background: #18181b;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .hunk-lines {
    background: #000000;
  }

  .line {
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    border-bottom: 1px solid #0f0f10;
  }

  .line:last-child {
    border-bottom: none;
  }

  .line-marker {
    display: inline-block;
    width: 2rem;
    flex-shrink: 0;
    padding: 0.25rem 0.5rem;
    text-align: center;
    user-select: none;
    font-weight: 600;
  }

  .line-content {
    flex: 1;
    padding: 0.25rem 1rem 0.25rem 0.5rem;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .line-addition {
    background: rgba(34, 197, 94, 0.1);
  }

  .line-addition .line-marker {
    background: rgba(34, 197, 94, 0.2);
    color: #22c55e;
  }

  .line-deletion {
    background: rgba(239, 68, 68, 0.1);
  }

  .line-deletion .line-marker {
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
  }

  .line-context {
    color: var(--color-text-muted);
  }

  .line-context .line-marker {
    color: var(--color-text-muted);
    opacity: 0.4;
  }

  @media (max-width: 768px) {
    .diff-dates {
      flex-direction: column;
    }

    .arrow-icon {
      transform: rotate(90deg);
    }

    .date-box {
      width: 100%;
    }

    .line {
      font-size: 0.75rem;
    }

    .line-marker {
      width: 1.5rem;
      padding: 0.25rem 0.25rem;
    }

    .line-content {
      padding: 0.25rem 0.5rem 0.25rem 0.25rem;
    }
  }

  @media (max-width: 480px) {
    .stats-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
