---
import Layout from '../../../layouts/Layout.astro'

interface DiffLine { type: string; content: string; oldLine?: number; newLine?: number }
interface DiffHunk { oldStart: number; oldLines: number; newStart: number; newLines: number; lines: DiffLine[] }
interface DiffData { fromHash: string; toHash: string; fromDate: string; toDate: string; hunks: DiffHunk[]; stats: { additions: number; deletions: number } }

export const prerender = false

const { id } = Astro.params
const url = new URL(Astro.request.url)
const fromHash = url.searchParams.get('from')
const toHash = url.searchParams.get('to')

if (!id || !fromHash || !toHash) {
  return Astro.redirect(`/leyes/${id}`)
}

let diff: DiffData | null = null
let error = ''

try {
  const res = await fetch(`${Astro.url.origin}/api/normas/${id}/diff?from=${fromHash}&to=${toHash}`)
  if (!res.ok) {
    throw new Error('Failed to fetch diff')
  }
  const { data } = await res.json()
  diff = data
} catch (e) {
  error = 'No se pudo cargar la comparación'
}

const fromDate = diff?.fromDate ? new Date(diff.fromDate).toLocaleDateString('es-PE') : ''
const toDate = diff?.toDate ? new Date(diff.toDate).toLocaleDateString('es-PE') : ''
---

<Layout title={`Comparar versiones — ${id}`}>
  <main id="main-content">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span>/</span>
        <a href="/leyes">Normas</a>
        <span>/</span>
        <a href={`/leyes/${id}`}>{id}</a>
        <span>/</span>
        <span>Comparar</span>
      </nav>

      {error ? (
        <div class="error-box">
          <p>{error}</p>
          <a href={`/leyes/${id}`} class="btn btn-primary">Volver a la norma</a>
        </div>
      ) : diff && (
        <>
          <div class="diff-header">
            <h1>Comparación de versiones</h1>
            <div class="diff-meta">
              <div class="diff-version diff-from">
                <span class="version-label">Anterior</span>
                <span class="version-hash">{fromHash.slice(0, 7)}</span>
                <span class="version-date">{fromDate}</span>
              </div>
              <svg class="arrow" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
              <div class="diff-version diff-to">
                <span class="version-label">Nueva</span>
                <span class="version-hash">{toHash.slice(0, 7)}</span>
                <span class="version-date">{toDate}</span>
              </div>
            </div>
            <div class="diff-stats">
              <span class="stat stat-add">+{diff.stats.additions} líneas</span>
              <span class="stat stat-del">-{diff.stats.deletions} líneas</span>
            </div>
          </div>

          <div class="diff-content" role="region" aria-label="Cambios en el código">
            {diff.hunks.length === 0 ? (
              <div class="no-changes">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M9 12l2 2 4-4"/>
                  <circle cx="12" cy="12" r="10"/>
                </svg>
                <p>Sin cambios en esta comparación</p>
                <span class="no-changes-hint">Las versiones seleccionadas son idénticas para este archivo.</span>
              </div>
            ) : (
              diff.hunks.map((hunk) => (
                <div class="diff-hunk" role="group" aria-label={`Bloque de cambios: líneas ${hunk.oldStart}-${hunk.oldStart + hunk.oldLines}`}>
                  <div class="hunk-header" aria-hidden="true">
                    @@ -{hunk.oldStart},{hunk.oldLines} +{hunk.newStart},{hunk.newLines} @@
                  </div>
                  <div class="hunk-lines" role="list">
                    {hunk.lines.map((line) => (
                      <div
                        class={`diff-line diff-${line.type}`}
                        role="listitem"
                        aria-label={line.type === 'add' ? 'Línea añadida' : line.type === 'del' ? 'Línea eliminada' : 'Línea sin cambios'}
                      >
                        <span class="line-num line-num-old" aria-hidden="true">{line.oldLine ?? ''}</span>
                        <span class="line-num line-num-new" aria-hidden="true">{line.newLine ?? ''}</span>
                        <span class="line-prefix" aria-hidden="true">{line.type === 'add' ? '+' : line.type === 'del' ? '-' : ' '}</span>
                        <span class="line-content">{line.content}</span>
                      </div>
                    ))}
                  </div>
                </div>
              ))
            )}
          </div>

          <div class="diff-actions">
            <a href={`/leyes/${id}/version/${fromHash}`} class="btn btn-secondary">Ver versión anterior</a>
            <a href={`/leyes/${id}/version/${toHash}`} class="btn btn-secondary">Ver versión nueva</a>
            <a href={`/leyes/${id}`} class="btn btn-primary">Ver versión actual</a>
          </div>
        </>
      )}
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .diff-header {
    margin-bottom: 2rem;
  }

  .diff-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .diff-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .diff-version {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .version-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .version-hash {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .version-date {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .arrow {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .diff-stats {
    display: flex;
    gap: 1rem;
  }

  .stat {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .stat-add { color: #22c55e; }
  .stat-del { color: #ef4444; }

  .diff-content {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .diff-hunk {
    border-bottom: 1px solid var(--color-border);
  }

  .diff-hunk:last-child {
    border-bottom: none;
  }

  .hunk-header {
    background: #1a1a2e;
    color: #a5a5c0;
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .hunk-lines {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .diff-line {
    display: flex;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .diff-context { background: var(--color-bg); }
  .diff-add { background: rgba(34, 197, 94, 0.15); }
  .diff-del { background: rgba(239, 68, 68, 0.15); }

  .line-num {
    width: 3.5rem;
    padding: 0 0.5rem;
    text-align: right;
    color: var(--color-text-muted);
    user-select: none;
    flex-shrink: 0;
    border-right: 1px solid var(--color-border);
  }

  .line-prefix {
    width: 1.5rem;
    text-align: center;
    flex-shrink: 0;
    user-select: none;
  }

  .diff-add .line-prefix { color: #22c55e; }
  .diff-del .line-prefix { color: #ef4444; }

  .line-content {
    flex: 1;
    padding: 0 0.5rem;
  }

  .diff-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.875rem;
    transition: all 0.2s;
    text-decoration: none;
  }

  .btn-primary {
    background: #ffffff;
    color: #000000;
  }

  .btn-primary:hover { background: #cccccc; }

  .btn-secondary {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-secondary:hover { background: var(--color-border); }

  .error-box {
    text-align: center;
    padding: 4rem 2rem;
  }

  .error-box p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .no-changes {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 3rem 2rem;
    text-align: center;
    color: var(--color-text-muted);
  }

  .no-changes svg {
    opacity: 0.5;
    color: #22c55e;
  }

  .no-changes p {
    font-size: 1rem;
    margin: 0;
  }

  .no-changes-hint {
    font-size: 0.85rem;
    opacity: 0.7;
  }

  /* Accessibility: Add visual indicators beyond color */
  .diff-del .line-content {
    text-decoration: line-through;
    text-decoration-color: rgba(239, 68, 68, 0.6);
  }

  .diff-add .line-content {
    border-left: 2px solid #22c55e;
    padding-left: 0.5rem;
    margin-left: -0.5rem;
  }

  @media (max-width: 640px) {
    .diff-meta {
      flex-direction: column;
      align-items: flex-start;
    }

    .arrow {
      transform: rotate(90deg);
    }

    .line-num {
      width: 2.5rem;
      font-size: 0.75rem;
    }
  }
</style>
