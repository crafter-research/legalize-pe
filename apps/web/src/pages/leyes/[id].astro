---
export const prerender = true

import { readFileSync, readdirSync, statSync } from 'node:fs'
import { join, relative } from 'node:path'
import { marked } from 'marked'
import Layout from '../../layouts/Layout.astro'

interface LeyFrontmatter {
  titulo: string
  identificador: string
  pais: string
  jurisdiccion: string
  rango: string
  fechaPublicacion: string
  ultimaActualizacion: string
  estado: string
  fuente: string
  diarioOficial: string
  ocrProcessed?: boolean
  ocrQuality?: 'poor' | 'medium' | 'good'
}

function parseFrontmatter(content: string): { meta: LeyFrontmatter; body: string } {
  const parts = content.split(/^---\s*$/m)
  const yamlBlock = parts[1] ?? ''
  const body = parts.slice(2).join('---').trim()
  const result: Record<string, string | boolean> = {}
  for (const line of yamlBlock.split('\n')) {
    const match = line.match(/^(\w+):\s*"?([^"]*?)"?\s*$/)
    if (match) {
      const value = match[2].trim()
      // Handle boolean values
      if (value === 'true') {
        result[match[1]] = true
      } else if (value === 'false') {
        result[match[1]] = false
      } else {
        result[match[1]] = value
      }
    }
  }
  return { meta: result as unknown as LeyFrontmatter, body }
}

function getAllMdFiles(dir: string, baseDir: string = dir): string[] {
  const files: string[] = []
  for (const entry of readdirSync(dir)) {
    if (entry.startsWith('.')) continue
    const fullPath = join(dir, entry)
    const stat = statSync(fullPath)
    if (stat.isDirectory()) {
      files.push(...getAllMdFiles(fullPath, baseDir))
    } else if (entry.endsWith('.md')) {
      files.push(relative(baseDir, fullPath))
    }
  }
  return files
}

const leyesDir = join(process.cwd(), '../../leyes/pe')

function buildIdToFileMap(dir: string): Map<string, string> {
  const map = new Map<string, string>()
  const files = getAllMdFiles(dir)
  for (const filename of files) {
    const content = readFileSync(join(dir, filename), 'utf-8')
    const parts = content.split(/^---\s*$/m)
    const yamlBlock = parts[1] ?? ''
    for (const line of yamlBlock.split('\n')) {
      const match = line.match(/^identificador:\s*"?([^"]*?)"?\s*$/)
      if (match) {
        map.set(match[1].trim(), filename)
        break
      }
    }
    const idFromFilename = filename.replace(/\.md$/, '').replace(/\//g, '-')
    if (!map.has(idFromFilename)) {
      map.set(idFromFilename, filename)
    }
  }
  return map
}

export async function getStaticPaths() {
  const dir = join(process.cwd(), '../../leyes/pe')
  const idToFileMap = buildIdToFileMap(dir)
  return [...idToFileMap.entries()].map(([id, filename]) => ({
    params: { id },
    props: { filename },
  }))
}

const { id } = Astro.params
const { filename } = Astro.props

const rawContent = readFileSync(join(leyesDir, filename), 'utf-8')
const { meta, body } = parseFrontmatter(rawContent)

const rangoLabels: Record<string, string> = {
  constitucion: 'Constitución',
  ley: 'Ley',
  'decreto-legislativo': 'Decreto Legislativo',
  'decreto-urgencia': 'Decreto de Urgencia',
  'decreto-supremo': 'Decreto Supremo',
}

const rawContentEscaped = JSON.stringify(rawContent)
const htmlContent = await marked(body)
---

<Layout title={`${meta.titulo} — Legalize PE`} description={`${meta.titulo}. ${rangoLabels[meta.rango] ?? meta.rango} peruana publicada el ${meta.fechaPublicacion}.`}>
  <main id="main-content">
    <div class="container">
      <nav class="breadcrumb" aria-label="Navegación de ruta">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/leyes">Normas</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{id}</span>
      </nav>

      <div class="page-top">
        <div class="page-header">
          <h1>{meta.titulo}</h1>
          <div class="meta-badges">
            <span class="badge badge-rango">
              {rangoLabels[meta.rango] ?? meta.rango}
            </span>
            {meta.estado === 'vigente' && (
              <span class="badge badge-vigente">Vigente</span>
            )}
          </div>
          {meta.ocrQuality === 'poor' && (
            <div class="ocr-warning" role="alert">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
              <div>
                <strong>Calidad de texto limitada</strong>
                <p>Este documento fue procesado con OCR desde un PDF escaneado antiguo. El texto puede contener errores de reconocimiento.</p>
              </div>
            </div>
          )}
          <dl class="meta-grid">
            <div>
              <dt>Publicacion</dt>
              <dd>{meta.fechaPublicacion}</dd>
            </div>
            <div>
              <dt>Ultima actualizacion</dt>
              <dd>{meta.ultimaActualizacion}</dd>
            </div>
            {meta.diarioOficial && (
              <div>
                <dt>Diario Oficial</dt>
                <dd>{meta.diarioOficial}</dd>
              </div>
            )}
            {meta.fuente && (
              <div>
                <dt>Fuente</dt>
                <dd>
                  <a href={meta.fuente} target="_blank" rel="noopener">
                    SPIJ / Minjus<span class="sr-only"> (abre en nueva ventana)</span> &nearr;
                  </a>
                </dd>
              </div>
            )}
          </dl>
        </div>

        <div class="action-buttons">
          <button id="btn-copy" class="btn btn-primary" type="button">
            Copiar Markdown
          </button>
          <button id="btn-download" class="btn btn-secondary" type="button">
            Descargar .md
          </button>
        </div>
      </div>

      <section class="version-history">
        <button id="history-toggle" class="history-toggle-btn" aria-expanded="false" aria-controls="history-content">
          <svg class="history-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>Historial de versiones</span>
          <span id="history-count" class="history-count-badge"></span>
          <svg class="chevron" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
        <div id="history-content" class="history-content" hidden aria-hidden="true">
          <div id="history-list"></div>
        </div>
      </section>

      <article class="content-box prose" set:html={htmlContent} />
    </div>
  </main>
</Layout>

<script define:vars={{ rawContent: rawContentEscaped, filename, identificador: id }}>
  const raw = JSON.parse(rawContent)

  const btnCopy = document.getElementById('btn-copy')
  const btnDownload = document.getElementById('btn-download')

  btnCopy?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(raw)
      btnCopy.textContent = 'Copiado!'
      setTimeout(() => {
        btnCopy.textContent = 'Copiar Markdown'
      }, 2000)
    } catch {
      btnCopy.textContent = 'Error al copiar'
      setTimeout(() => {
        btnCopy.textContent = 'Copiar Markdown'
      }, 2000)
    }
  })

  btnDownload?.addEventListener('click', () => {
    const blob = new Blob([raw], { type: 'text/markdown;charset=utf-8' })
    const url = URL.createObjectURL(blob)
    const anchor = document.createElement('a')
    anchor.href = url
    anchor.download = filename
    document.body.appendChild(anchor)
    anchor.click()
    document.body.removeChild(anchor)
    URL.revokeObjectURL(url)
  })

  // Version History
  const toggleBtn = document.getElementById('history-toggle')
  const content = document.getElementById('history-content')
  const historyList = document.getElementById('history-list')
  const countSpan = document.getElementById('history-count')
  let loaded = false

  // Load history count on page load
  async function loadHistoryCount() {
    try {
      const res = await fetch(`/api/normas/${identificador}/history`)
      const { data } = await res.json()
      if (data && data.length > 0) {
        countSpan.textContent = data.length
        countSpan.classList.add('visible')
      }
    } catch {}
  }
  loadHistoryCount()

  toggleBtn?.addEventListener('click', async () => {
    const isHidden = content.hidden
    content.hidden = !isHidden
    content.setAttribute('aria-hidden', String(!isHidden))
    toggleBtn.setAttribute('aria-expanded', String(isHidden))
    toggleBtn.classList.toggle('expanded', isHidden)

    if (isHidden && !loaded) {
      historyList.innerHTML = '<p class="loading">Cargando historial...</p>'
      try {
        const res = await fetch(`/api/normas/${identificador}/history`)
        const { data } = await res.json()
        loaded = true

        if (!data || data.length === 0) {
          historyList.innerHTML = `
            <div class="empty-state">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <p>Esta norma aún no tiene historial de cambios registrados.</p>
              <span class="empty-hint">El historial se genera cuando se registran modificaciones oficiales.</span>
            </div>
          `
          return
        }

        const latestHash = data[0].hash
        historyList.innerHTML = data.map((commit, i) => `
          <div class="history-item">
            <div class="commit-info">
              <span class="commit-date">${new Date(commit.authorDate).toLocaleDateString('es-PE', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              <span class="commit-message">${commit.subject}</span>
            </div>
            <div class="commit-actions">
              <a href="/leyes/${identificador}/version/${commit.hash}" class="btn-small" title="Ver esta versión">Ver</a>
              ${i < data.length - 1 ? `<a href="/leyes/${identificador}/diff?from=${data[i+1].hash}&to=${commit.hash}" class="btn-small btn-outline" title="Comparar con versión anterior">Comparar</a>` : '<span class="btn-small btn-disabled" title="Versión inicial">Inicial</span>'}
            </div>
          </div>
        `).join('')
      } catch (err) {
        historyList.innerHTML = `
          <div class="error-state">
            <p>Error al cargar el historial</p>
            <button onclick="location.reload()" class="btn-small">Reintentar</button>
          </div>
        `
      }
    }
  })
</script>

<style>
