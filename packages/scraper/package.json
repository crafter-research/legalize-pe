{
  "name": "@legalize-pe/scraper",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "scrape": "tsx src/scrape-final.ts",
    "scrape:direct": "tsx src/scrape-direct.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --external playwright",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "domhandler": "^5.0.3",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "playwright": "^1.59.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
